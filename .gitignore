# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# agent tools
.atl/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.vitest/
playwright-report/
test-results/
tests/e2e/fixtures/.auth/
tests/e2e/.auth/
tests/e2e/.db-state.json
.playwright-cache/

# env test overrides
.env.e2e
.env.test.local

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/src/generated/
/prisma/generated/

.opencode/

# office temporary lock files
~$*.xlsx

# data export / review spreadsheets
/tours-revision-*.xlsx

# generated seed migration artifacts (logs, dry-runs, reports)
# inputs (baselines, source bases) stay tracked; only generated output is ignored
prisma/seed/data/*.log
prisma/seed/data/*-DRYRUN.*
prisma/seed/data/Diff_*.xlsx
prisma/seed/data/Orphan_*.xlsx
prisma/seed/data/Consolidate_*.xlsx
prisma/seed/data/App_Data_Backup_*.xlsx
prisma/seed/data/fix-*.csv

# scratch temp files
_tmp_*

# playwright
.playwright-mcp/
.jez/
